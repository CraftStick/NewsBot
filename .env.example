# Скопируйте на сервер: cp .env.example .env && nano .env

TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Куда слать по расписанию: preview (только личка) или channel (автопост в канал)
DIGEST_MODE=preview

# Канал — только если DIGEST_MODE=channel или флаги -run-once / -run-in
# TELEGRAM_CHANNEL_ID=-1001234567890

# Ваш личный chat id (для -preview): /start боту → getUpdates
TELEGRAM_PREVIEW_CHAT_ID=123456789

# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

TZ=Europe/Moscow

# Расписание (5 полей cron: мин час день месяц день_недели)
# Прод: пятница 18:00
CRON_SCHEDULE=0 18 * * 5
# Тест: каждую минуту (не оставляйте на проде!)
# CRON_SCHEDULE=*/1 * * * *

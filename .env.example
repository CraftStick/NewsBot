# Скопируйте на сервер: cp .env.example .env && nano .env

TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Канал (для -run-once и планировщика): -100xxxxxxxxxx или @channel_username
TELEGRAM_CHANNEL_ID=-1001234567890

# Ваш личный chat id (для -preview): /start боту → getUpdates
TELEGRAM_PREVIEW_CHAT_ID=123456789

# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

TZ=Europe/Moscow

# Расписание (5 полей cron: мин час день месяц день_недели)
# Прод: пятница 18:00
CRON_SCHEDULE=0 18 * * 5
# Тест: каждую минуту (не оставляйте на проде!)
# CRON_SCHEDULE=*/1 * * * *

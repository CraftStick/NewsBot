# Скопируйте в .env и заполните значениями.

# Telegram Bot API (бот должен быть админом канала)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# ID канала: -100xxxxxxxxxx или @channel_username
TELEGRAM_CHANNEL_ID=-1001234567890

# Google AI Studio — бесплатный ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Модель (по умолчанию gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Часовой пояс для пятницы 18:00 (по умолчанию Europe/Moscow)
TZ=Europe/Moscow

# Тип превью перед дайджестом: photo | sticker | animation
MEDIA_TYPE=photo

# Шапка, подзаголовок и прощание с emoji — в format.go (не в .env)

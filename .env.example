# Скопируйте: cp .env.example .env
# Секреты не коммитьте. На VPS: /opt/treesheild-newsbot/.env (chmod 600)

# --- Telegram ---
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Ваш chat id: /start боту → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_PREVIEW_CHAT_ID=

# --- Google Gemini ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Расписание ---
# Часовой пояс для cron
TZ=Europe/Moscow
# 5 полей: минуты часы день месяц день_недели (5 = пятница)
CRON_SCHEDULE=0 18 * * 5

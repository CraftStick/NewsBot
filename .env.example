# Copy: cp .env.example .env
# Do not commit secrets. On VPS: /opt/treesheild-newsbot/.env (chmod 600)
# Скопируйте: cp .env.example .env — не коммитьте секреты

# --- Telegram ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your chat id: /start the bot → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_PREVIEW_CHAT_ID=

# --- Google Gemini ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Schedule ---
TZ=Europe/Moscow
# 5 fields: minute hour day month weekday (5 = Friday)
CRON_SCHEDULE=0 18 * * 5
